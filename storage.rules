rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function isAdmin() {
      return request.auth != null && request.auth.token.admin == true;
    }

    function isValidPublicImageUpload() {
      return request.resource.size <= 10 * 1024 * 1024
        && request.resource.contentType.matches('image/(jpeg|png|webp)');
    }

    // Sensitive student ID images are written by Admin SDK and read by admins only.
    match /verification_requests/{requestId}/{imageType} {
      allow write: if false;
      allow read: if isAdmin();
    }

    // Public media managed by admins.
    match /vendors/{vendorId}/{allPaths=**} {
      allow read: if true;
      allow create, update: if isAdmin() && isValidPublicImageUpload();
      allow delete: if isAdmin();
    }

    match /banners/{allPaths=**} {
      allow read: if true;
      allow create, update: if isAdmin() && isValidPublicImageUpload();
      allow delete: if isAdmin();
    }

    match /trending-offer-banners/{allPaths=**} {
      allow read: if true;
      allow create, update: if isAdmin() && isValidPublicImageUpload();
      allow delete: if isAdmin();
    }

    match /featured-brand-showcase/{brandId}/{section}/{fileName} {
      allow read: if true;
      allow create, update: if isAdmin() && isValidPublicImageUpload();
      allow delete: if isAdmin();
    }

    match /universities/{allPaths=**} {
      allow read: if true;
      allow create, update: if isAdmin() && isValidPublicImageUpload();
      allow delete: if isAdmin();
    }

    match /brands/{allPaths=**} {
      allow read: if true;
      allow create, update: if isAdmin() && isValidPublicImageUpload();
      allow delete: if isAdmin();
    }

    match /categories/{allPaths=**} {
      allow read: if true;
      allow create, update: if isAdmin() && isValidPublicImageUpload();
      allow delete: if isAdmin();
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
